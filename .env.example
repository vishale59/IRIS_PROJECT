# Environment variables for the IRIS Job Portal.
SECRET_KEY=change-this-secret-key
FLASK_ENV=development
USE_SQLITE_FALLBACK=true
SQLITE_DATABASE_URI=sqlite:///instance/iris_job_portal.db
DB_DRIVER=mysql+pymysql
DB_HOST=localhost
DB_PORT=3306
DB_NAME=iris_job_portal
DB_USER=root
DB_PASSWORD=password
DATABASE_URL=
UPLOAD_FOLDER=uploads
MAX_CONTENT_LENGTH=8388608
